# Google AI Studio (simplest)
GOOGLE_API_KEY=your_api_key_here

# -- OR -- Vertex AI (enterprise)
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_GENAI_USE_VERTEXAI=true

# Google OAuth (from GCP Console > APIs & Services > Credentials)
GOOGLE_OAUTH_CLIENT_ID=your_client_id_here
GOOGLE_OAUTH_CLIENT_SECRET=your_client_secret_here
# SESSION_SECRET=random-secret-for-signing-cookies

# Frontend origin (for OAuth redirect in dev; omit in prod when backend serves frontend)
BASE_URL=http://localhost:5173
